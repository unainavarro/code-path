---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Information from "../components/Information.astro";
import Projects from "../components/Projects.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
---

<Layout title="Code-Path">
  <Header
    src="../public/img/logo-black.svg"
    alt="code logo"
    title="Code Path"
  />
  <Information
    title="¿Qué encontraras?"
    body=`Code Path es una web que recopila materiales útiles para aprender, 
	practicar y mejorar en programación. 
	Aquí encontrarás una combinación de apuntes teóricos, 
	ejercicios prácticos y recursos adicionales que cubren una amplia variedad de temas relacionados con el desarrollo de software.`
  />
  <Projects title="Temas">
    <Card
      title="JavaScript"
      description="Aprende JavaScript mediante la realización de proyectos"
      firstBtn
      firstBtnHref="projects/javascript"
      firstBtnText="Empezar"
    />
  </Projects>

  <Footer />
</Layout>
